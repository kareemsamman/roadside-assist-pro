# Autodesk Platform Services (APS) credentials
APS_CLIENT_ID=your_client_id_here
APS_CLIENT_SECRET=your_client_secret_here

# APS Object Storage bucket (auto-created if missing)
APS_BUCKET_KEY=roadside-assist-pro

# APS Design Automation activity
# Format: <owner>.<activity_name>+<alias>
# This is created by running: npm run setup-da
APS_ACTIVITY_ID=

# Server
PORT=3001
CORS_ORIGIN=http://localhost:8080
